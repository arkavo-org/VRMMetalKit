ion\/VRMMetalKit\/VRMModel\/load(from:device:options:)","type":"reference","isActive":true},{"text":" to control progress reporting, cancellation, and load-time optimizations.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VRMLoadingOptions"}],"navigatorTitle":[{"kind":"identifier","text":"VRMLoadingOptions"}],"kind":"symbol","type":"topic","title":"VRMLoadingOptions"},"doc://VRMMetalKit/documentation/VRMMetalKit/VRMMToonMaterial":{"kind":"symbol","url":"\/documentation\/vrmmetalkit\/vrmmtoonmaterial","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMToonMaterial","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VRMMToonMaterial"}],"title":"VRMMToonMaterial","navigatorTitle":[{"kind":"identifier","text":"VRMMToonMaterial"}],"type":"topic","abstract":[{"text":"MToon 1.0 non-photorealistic material parameters as defined by the ","type":"text"},{"code":"VRMC_materials_mtoon","type":"codeVoice"},{"text":" extension.","type":"text"}]},"doc://VRMMetalKit/documentation/VRMMetalKit/LoadingVRMModels":{"role":"collectionGroup","title":"Loading VRM Models","type":"topic","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/LoadingVRMModels","url":"\/documentation\/vrmmetalkit\/loadingvrmmodels","kind":"article","abstract":[{"text":"Pick the right loader entry point, drive a progress bar, cancel mid-load, and handle errors.","type":"text"}]}}}