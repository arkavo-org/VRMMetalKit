{"hierarchy":{"paths":[["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit"]]},"metadata":{"roleHeading":"API Collection","role":"collectionGroup","modules":[{"name":"VRMMetalKit"}],"title":"Getting Started with VRMMetalKit"},"abstract":[{"text":"Set up a Metal-backed VRM renderer in under twenty lines of Swift.","type":"text"}],"seeAlsoSections":[{"anchor":"Essentials","identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMetalKit","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMSpecVersion","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMConstants","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMHumanoid","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMHumanoidBone","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMFirstPerson","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMFirstPersonFlag","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLookAt","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMExpressions"],"generated":true,"title":"Essentials"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This article walks through the minimum integration: adding the package, loading a VRM 1.0 avatar from disk, and drawing it into an "},{"type":"codeVoice","code":"MTKView"},{"type":"text","text":". It’s aimed at developers who already have a Metal-based app and want to drop in a VRM runtime without reaching for a higher-level engine."}],"type":"paragraph"},{"inlineContent":[{"text":"VRMMetalKit targets ","type":"text"},{"inlineContent":[{"text":"macOS 26+","type":"text"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"iOS 26+","type":"text"}],"type":"strong"},{"text":" and is written in ","type":"text"},{"inlineContent":[{"text":"Swift 6.2","type":"text"}],"type":"strong"},{"text":" with strict concurrency. The public surface is ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":"-aware, but the renderer itself is main-actor-bound — keep that in mind when wiring it into your view hierarchy. Once you have a basic frame on screen, see the sister articles linked at the bottom for animation, ARKit driving, physics, and validation.","type":"text"}],"type":"paragraph"},{"text":"Add the package","anchor":"Add-the-package","level":2,"type":"heading"},{"inlineContent":[{"text":"In Xcode, choose ","type":"text"},{"inlineContent":[{"type":"text","text":"File ▸ Add Package Dependencies…"}],"type":"strong"},{"text":" and enter ","type":"text"},{"code":"https:\/\/github.com\/arkavo-org\/VRMMetalKit","type":"codeVoice"},{"text":". Pin to version ","type":"text"},{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"strong"},{"text":" or later.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For a ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":"-based project, add the dependency directly:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":[".package(url: \"https:\/\/github.com\/arkavo-org\/VRMMetalKit\", from: \"1.0.0\")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then add "},{"code":"\"VRMMetalKit\"","type":"codeVoice"},{"type":"text","text":" to the "},{"code":"dependencies","type":"codeVoice"},{"type":"text","text":" of any target that needs it."}],"type":"paragraph"},{"text":"Load and render a model","anchor":"Load-and-render-a-model","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The example below uses "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMetalKit\/loadModel(from:device:)-9dmyj","type":"reference","isActive":true},{"type":"text","text":" to read a "},{"code":".vrm","type":"codeVoice"},{"type":"text","text":" file off disk, hands the resulting "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","type":"reference","isActive":true},{"type":"text","text":" to a freshly created "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMRenderer","type":"reference","isActive":true},{"type":"text","text":", and drives that renderer from an "},{"code":"MTKViewDelegate","type":"codeVoice"},{"type":"text","text":". The class is "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" because "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMRenderer\/draw(in:commandBuffer:renderPassDescriptor:)","type":"reference","isActive":true},{"type":"text","text":" must be called from the main actor."}],"type":"paragraph"},{"syntax":"swift","code":["import VRMMetalKit","import Metal","import MetalKit","","@MainActor","final class AvatarRenderer: NSObject, MTKViewDelegate {","    private let device: MTLDevice","    private let commandQueue: MTLCommandQueue","    private let renderer: VRMRenderer","","    init() throws {","        guard let device = MTLCreateSystemDefaultDevice() else {","            throw RenderSetupError.noDevice","        }","        self.device = device","        self.commandQueue = device.makeCommandQueue()!","        self.renderer = VRMRenderer(device: device)","    }","","    func load(modelURL: URL) async throws {","        let model = try await VRMMetalKit.loadModel(from: modelURL, device: device)","        renderer.loadModel(model)","    }","","    func mtkView(_ view: MTKView, drawableSizeWillChange size: CGSize) {}","","    func draw(in view: MTKView) {","        guard","            let drawable = view.currentDrawable,","            let descriptor = view.currentRenderPassDescriptor,","            let commandBuffer = commandQueue.makeCommandBuffer()","        else { return }","","        renderer.draw(in: view, commandBuffer: commandBuffer, renderPassDescriptor: descriptor)","        commandBuffer.present(drawable)","        commandBuffer.commit()","    }","}","","enum RenderSetupError: Error { case noDevice }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Set the "},{"code":"MTKView","type":"codeVoice"},{"type":"text","text":"’s delegate to your "},{"code":"AvatarRenderer","type":"codeVoice"},{"type":"text","text":" instance (with a depth attachment on the view) and call "},{"code":"await avatarRenderer.load(modelURL:)","type":"codeVoice"},{"type":"text","text":" once you have a file URL. The renderer ships with a default 3-point lighting rig, so the avatar is visible without further configuration."}],"type":"paragraph"},{"text":"Next steps","anchor":"Next-steps","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/LoadingVRMModels","isActive":true},{"type":"text","text":" — VRM file format details and untrusted-input handling"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/RenderingAvatars"},{"type":"text","text":" — "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/RendererConfig"},{"type":"text","text":" tuning, MSAA, outlines"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationAndRetargeting","isActive":true},{"type":"text","text":" — playing "},{"type":"codeVoice","code":".vrma"},{"type":"text","text":" clips with humanoid retargeting"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitIntegration","isActive":true,"type":"reference"},{"type":"text","text":" — face and body driving from ARKit"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SpringBonePhysics","isActive":true,"type":"reference"},{"text":" — hair and cloth physics on the GPU","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictMode","isActive":true,"type":"reference"},{"text":" — runtime validation for renderer bindings","type":"text"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MigratingFromVRM0","type":"reference","isActive":true},{"type":"text","text":" — handling 0.x files alongside 1.0"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/vrmmetalkit\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","sections":[],"identifier":{"url":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/GettingStarted","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Essential-types","identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMetalKit","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMRenderer","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/RendererConfig"],"title":"Essential types"}],"references":{"doc://VRMMetalKit/documentation/VRMMetalKit/VRMRenderer/draw(in:commandBuffer:renderPassDescriptor:)":{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMRenderer\/draw(in:commandBuffer:renderPassDescriptor:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"draw"},{"kind":"text","text":"("},{"kind":"externalParam","text":"in"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)MTKView","text":"MTKView"},{"kind":"text","text":", "},{"kind":"externalParam","text":"commandBuffer"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(pl)MTLCommandBuffer","text":"MTLCommandBuffer"},{"kind":"text","text":", "},{"kind":"externalParam","text":"renderPassDescriptor"},{"kind":"text","text":": "},{"kind":"typeIdentifier",