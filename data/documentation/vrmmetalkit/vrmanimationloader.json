{"topicSections":[{"generated":true,"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationLoader\/loadVRMA(from:model:)"],"anchor":"Type-Methods","title":"Type Methods"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationAndRetargeting","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationClip","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/JointTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MorphTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ExpressionTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/NodeTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/EulerAxis","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationLibrary","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMSkinningSystem","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkinnedShader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationState","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationState\/BoneTransform","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationPresets","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMorphTargetSystem"],"anchor":"Animation","title":"Animation"}],"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationLoader"},"abstract":[{"text":"Loads VRMC_vrm_animation-1.0 (","type":"text"},{"code":".vrma","type":"codeVoice"},{"text":") clips and retargets their tracks onto a target ","type":"text"},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","isActive":true,"type":"reference"},{"text":".","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VRMAnimationLoader","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"codeVoice","code":"VRMAnimationLoader"},{"type":"text","text":" is the retargeting nerve centre. VRMA files store"},{"type":"text","text":" "},{"type":"text","text":"animation in their own skeleton’s rest pose, which is typically "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" the"},{"type":"text","text":" "},{"type":"text","text":"rest pose of the avatar the animation is being applied to. The loader"},{"type":"text","text":" "},{"type":"text","text":"resolves this by producing per-frame closures that bake the retargeting"},{"type":"text","text":" "},{"type":"text","text":"math at load time, so playback (via "},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer","isActive":true},{"type":"text","text":") only has to"},{"type":"text","text":" "},{"type":"text","text":"sample and write."}],"type":"paragraph"},{"text":"Rest-pose retargeting formula","anchor":"Rest-pose-retargeting-formula","type":"heading","level":3},{"inlineContent":[{"text":"Animation rest pose and model rest pose are treated as two independent,","type":"text"},{"text":" ","type":"text"},{"text":"immutable sources of truth — neither is inferred from the other. For","type":"text"},{"text":" ","type":"text"},{"text":"every humanoid bone, the loader emits a rotation closure of the form:","type":"text"}],"type":"paragraph"},{"code":["delta  = inverse(animationRestRotation) * animationRotation","result = modelRestRotation * delta"],"syntax":"text","type":"codeListing"},{"inlineContent":[{"text":"This works whether the two rest poses are identical (delta collapses to","type":"text"},{"text":" ","type":"text"},{"code":"animationRotation","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"result = modelRest * animationRotation","type":"codeVoice"},{"text":") or","type":"text"},{"text":" ","type":"text"},{"text":"different (T-pose model receiving an A-pose animation, etc.). When the","type":"text"},{"text":" ","type":"text"},{"text":"model rest is unavailable (non-humanoid nodes, model-less load), the","type":"text"},{"text":" ","type":"text"},{"text":"closure passes the animation rotation through directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Translation deltas use the additive form","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"result = modelRest + (animTranslation - animRest)"},{"text":" and are emitted only","type":"text"},{"text":" ","type":"text"},{"text":"for the ","type":"text"},{"type":"codeVoice","code":"Hips"},{"text":" bone per the VRMC_vrm_animation spec.","type":"text"}],"type":"paragraph"},{"text":"Bone mapping precedence","anchor":"Bone-mapping-precedence","type":"heading","level":3},{"inlineContent":[{"text":"Humanoid node-to-bone mapping is resolved in this order:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The VRMC_vrm_animation extension’s "},{"code":"humanoid.humanBones","type":"codeVoice"},{"type":"text","text":" table on the"},{"type":"text","text":" "},{"type":"text","text":"animation file (per-spec source of truth)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The model’s "},{"code":"humanoid.getBoneNode","type":"codeVoice"},{"type":"text","text":" table matched by normalised name"},{"type":"text","text":" "},{"type":"text","text":"(lowercased, alphanumeric-only)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A relaxed substring match against the model’s normalised name table."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A heuristic that recognises both VRM 1.0 (","type":"text"},{"type":"codeVoice","code":"leftUpperArm"},{"text":") and Unity \/","type":"text"},{"text":" ","type":"text"},{"text":"VRM 0.0 (","type":"text"},{"type":"codeVoice","code":"J_Bip_L_UpperArm"},{"text":") naming.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"Nodes that resolve to no humanoid bone are emitted as "},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/NodeTrack","isActive":true},{"type":"text","text":" "},{"type":"text","text":"entries (hair, bust, accessories)."}],"type":"paragraph"},{"text":"VRM 0.0 coordinate conversion","anchor":"VRM-00-coordinate-conversion","type":"heading","level":3},{"inlineContent":[{"text":"VRMA files use VRM 1.0 (glTF right-handed) coordinates. When the target","type":"text"},{"text":" ","type":"text"},{"text":"model is VRM 0.0 (Unity left-handed), every sampled rotation and","type":"text"},{"text":" ","type":"text"},{"text":"translation has its X and Z components negated before retargeting. This","type":"text"},{"text":" ","type":"text"},{"text":"matches the conversion done by ","type":"text"},{"code":"three-vrm","type":"codeVoice"},{"text":"’s ","type":"text"},{"code":"createVRMAnimationClip.ts","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Spec-mandated skips","anchor":"Spec-mandated-skips","type":"heading","level":3},{"inlineContent":[{"text":"The loader silently drops tracks that the spec forbids:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Rotation\/translation\/scale on ","type":"text"},{"type":"codeVoice","code":"leftEye"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"rightEye"},{"text":" (gaze is driven","type":"text"},{"text":" ","type":"text"},{"text":"by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLookAtController","type":"reference"},{"text":" or the lookAt block).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"code":"lookUp","type":"c