ictModeError\/missingVertexAttribute(name:)"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Empty draw calls and out-of-range indices — ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/zeroVertices(primitive:)","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/zeroIndices(primitive:)","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/invalidIndexRange(max:vertexCount:)","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/noDrawCalls(expected:)","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Skinning and morph index ranges — ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/jointIndexOutOfBounds(joint:max:)","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/invalidJointCount(expected:actual:)","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/morphIndexOutOfBounds(index:max:)","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/morphWeightInvalid(index:weight:)","type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Command-buffer status at frame end — "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/StrictModeError\/commandBufferFailed(error:)"},{"type":"text","t