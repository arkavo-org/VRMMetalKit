},{"type":"text","text":"where the source texture is darkest. Use sparingly."}]}]}]}],"kind":"content"}],"metadata":{"title":"eyeEmissiveScale","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"eyeEmissiveScale","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"}],"modules":[{"name":"VRMMetalKit"}],"role":"symbol","roleHeading":"Instance Property","externalID":"s:11VRMMetalKit22SilhouetteRenderConfigV16eyeEmissiveScaleSfvp","symbolKind":"property"},"variants":[{"paths":["\/documentation\/vrmmetalkit\/silhouetterenderconfig\/eyeemissivescale"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://VRMMetalKit/documentation/VRMMetalKit/SilhouetteRenderConfig/eyeEmissiveScale":{"url":"\/documentation\/vrmmetalkit\/silhouetterenderconfig\/eyeemissivescale","title":"eyeEmissiveScale","abstract":[{"type":"text","text":"Emissive multiplier for eye materials. The iris\/sclera texture is"},{"type":"text","text":" "},{"type":"text","text":"sampled, multiplied by this scalar, and added to the lit pass. The"},{"type":"text","text":" "},{"text":"rasterizer then clamps to [0,1] per channel. Useful values:","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"eyeEmissiveScale","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"}],"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SilhouetteRenderConfig\/eyeEmissiveScale","role":"symbol","kind":"symbol","type":"topic"},"doc://VRMMetalKit/documentation/VRMMetalKit":{"type":"topic","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit","url":"\/documentation\/vrmmetalkit","kind":"symbol","title":"VRMMetalKit","role":"collection","abstract":[{"text":"High-performance loading, rendering, and animation of VRM 1.0 avatars on Apple platforms, built on Metal.","type":"text"}]},"doc://VRMMetalKit/documentation/V