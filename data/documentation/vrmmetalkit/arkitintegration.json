:)","abstract":[{"text":"Exponential Moving Average","type":"text"}],"kind":"symbol","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SmoothingFilter\/ema(alpha:)","role":"symbol","title":"SmoothingFilter.ema(alpha:)","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ema","kind":"identifier"},{"text":"(","kind":"text"},{"text":"alpha","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"},{"text":")","kind":"text"}]},"doc://VRMMetalKit/documentation/VRMMetalKit/AnimationPlayer":{"title":"AnimationPlayer","navigatorTitle":[{"text":"AnimationPlayer","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AnimationPlayer","kind":"identifier"}],"abstract":[{"text":"Drives an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationClip","type":"reference"},{"text":" against a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","type":"reference"},{"text":", advancing time and writing bone, node, morph, and look-at state each frame.","type":"text"}],"url":"\/documentation\/vrmmetalkit\/animationplayer","type":"topic"},"doc://VRMMetalKit/documentation/VRMMetalKit/ARKitFaceDriver/getStatistics()":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getStatistics"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:11VRMMetalKit16DriverStatisticsV","kind":"typeIdentifier","text":"DriverStatistics"}],"url":"\/documentation\/vrmmetalkit\/arkitfacedriver\/getstatistics()","abstract":[{"text":"Get update statistics","type":"text"}],"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitFaceDriver\/getStatistics()","role":"symbol","title":"get