,{"type":"paragraph","inlineContent":[{"type":"text","text":"IMPORTANT: This must match ARKitBodyDriver’s hierarchy exactly!"},{"type":"text","text":" "},{"type":"text","text":"ARKit provides world-space transforms, so we compute local rotations using:"},{"type":"text","text":" "},{"type":"text","text":"localRot = inverse(parentWorldRot) * childWorldRot"}]},{"type":"paragraph","inlineContent":[{"text":"Note: Upper arms connect directly to upperChest (not through shoulder).","type":"text"},{"text":" ","type":"text"},{"text":"This is because ARKit’s shoulder and arm data are independent - the shoulder","type":"text"},{"text":" ","type":"text"},{"text":"is a clavicle rotation, not a parent of the arm in the kinematic chain.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitCoordinateConverter\/arkitParentMap","interfaceLanguage":"swift"},"references":{"doc://VRMMetalKit/documentation/VRMMetalKit/ARKitJoint":{"navigatorTitle":[{"kind":"identifier","text":"ARKitJoint"}],"type":"topic","role":"symbol","url":"\/documentation\/vrmmetalkit\/arkitjoint","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ARKitJoint"}],"title":"ARKitJoint","kind":"symbol","abstract":[{"type":"text","text":"ARKit body joint identifiers"}],"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitJoint"},"doc://VRMMetalKit/documentation/VRMMetalKit/ARKitCoordinateConverter/arkitParentMap":{"title":"arkitParentMap","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitCoordinateConverter\/arkitParentMap","kind":"symbol","role":"symbol","url":"\/documentation\/vrmmetalkit\/arkitcoordinateconverter\/arkitparentmap","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"arkitParentMap"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:11VRMMetalKit10ARKit