dyDriver\/Statistics"],"generated":true,"title":"Structures","anchor":"Structures"},{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/init(mapper:smoothing:priority:stalenessThreshold:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/mapper","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/priority","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/stalenessThreshold"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/getStatistics()","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/invalidateCache()","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/resetFilters()","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/resetFilters(for:)","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/resetStatistics()","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/update(skeleton:nodes:humanoid:)","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/updateMulti(skeletons:nodes:humanoid:)"],"generated":true,"title":"Instance Methods","anchor":"Instance-Methods"},{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodyDriver\/SourcePriority"],"generated":true,"title":"Enumerations","anchor":"Enumerations"}],"abstract":[{"type":"text","text":"Drives the rotation of VRM humanoid bones from "},{"code":"ARBodyAnchor","type":"codeVoice"},{"type":"text","text":"-shaped skeleton data."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ARKitBodyDriver","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Per frame, the caller hands the driver a fresh "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodySkeleton"},{"type":"text","text":" snapshot (typically built from"},{"type":"text","text":" "},{"code":"ARBodyAnchor.skeleton","type":"codeVoice"},{"type":"text","text":"’s "},{"code":"jointModelTransforms","type":"codeVoice"},{"type":"text","text":" exposed by "},{"code":"ARSkeleton3D","type":"codeVoice"},{"type":"text","text":"). The driver:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Skips the frame if "},{"type":"codeVoice","code":"skeleton.isTracked"},{"type":"text","text":" is false."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For each ARKit joint with a "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitSkeletonMapper","isActive":true,"type":"reference"},{"type":"text","text":" entry, resolves the target VRM node via the"},{"type":"text","text":" "},{"type":"text","text":"humanoid map (preferred) or by node name."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Computes the joint’s local rotation by delegating to"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitCoordinateConverter\/computeVRMRotation(joint:childTransform:skeleton:)","isActive":true},{"type":"text","text":", which handles the"},{"type":"text","text":" "},{"type":"text","text":"parent-relative local conversion, A-pose-to-T-pose rest-pose offset, left-side mirroring, and root"},{"type":"text","text":" "},{"type":"text","text":"coordinate-system correction. Joints with a parent in "},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitCoordinateConverter\/arkitParentMap","isActive":true},{"type":"text","text":" "},{"type":"text","text":"whose parent transform is missing from the skeleton are skipped (the converter returns the"},{"type":"text","text":" "},{"type":"text","text":"identity quaternion, which the driver normalizes and applies as a safe rest pose)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Smooths each rotation via SLERP through ","type":"text"},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkeletonFilterManager","isActive":true,"type":"reference"},{"text":" if a ","type":"text"},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkeletonSmoothingConfig","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"is in use.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Normalizes the quaternion (and rejects NaN) before assigning ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMNode\/rotation","type":"reference"},{"text":" and updating","type":"text"},{"text":" ","type":"text"},{"text":"the node’s local and world transforms. Position and scale on the target nodes are left untouched","type":"text"},{"text":" ","type":"text"},{"text":"so the model’s rest pose is preserved.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Input-contract","level":2,"type":"heading","text":"Input contract"},{"inlineContent":[{"type":"text","text":"The driver consumes "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitBodySkeleton"},{"type":"text","text":", a transport-agnostic snapshot. ARKit’s "},{"code":"ARSkeleton3D","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"exposes joint transforms relative to the anchor ("},{"code":"jointModelTransforms","type":"codeVoice"},{"type":"text","text":") or relative to each joint’s"},{"type":"text","text":" "},{"type":"text","text":"parent ("},{"code":"jointLocalTransforms","type":"codeVoice"},{"type":"text","text":"); the driver expects world-space transforms, so callers typically"},{"type":"text","text":" "},{"type":"text","text":"compose "},{"code":"anchor.transform * jointModelTransform","type":"codeVoice"},{"type":"text","text":" before populating the "},{"code":"[ARKitJoint: simd_float4x4]","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"map. Only joints whose "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitJoint"},{"type":"text","text":" value is present in the configured"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitSkeletonMapper\/jointMap"},{"type":"text","text":" and in the skeleton are retargeted."}],"type":"paragraph"},{"anchor":"Output-contract","level":2,"type":"heading","text":"Output contract"},{"inlineContent":[{"text":"Drives whichever VRM humanoid bones are present in the configured mapper — by default the entire","type":"text"},{"text":" ","type":"text"},{"text":"humanoid set (torso, both arms with shoulders, both legs, and fingers); see","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitSkeletonMapper\/default"},{"text":". Restricted scenarios can use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitSkeletonMapper\/upperBodyOnly"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ARKitSkeletonMapper\/coreOnly"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Smoothing","level":2,"type":"heading","text":"Smoothing"},{"inlineContent":[{"type":"text","text":"Per-component smoothing is configured through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkeletonSmoothingConfig"},{"type":"text","text":" and applied by a lazily"},{"type":"text","text":" "},{"type":"text","text":"created "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkeletonFilterManager"},{"type":"text","text":". Customize by passing a config whose"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkeletonSmoothingConfig\/rotationFilter"},{"type":"text","text":" is the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SmoothingFilter"},{"type":"text","text":" of choice (EMA, Kalman, or"},{"type":"text","text":" "},{"type":"text","text":"windowed). The driver does not currently smooth positions or scales — only rotations."}],"type":"paragraph"},{"anchor":"Thread-Safety","level":2,"type":"heading","text":"Thread Safety"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Thread-safe."}],"type":"strong"},{"type":"text","text":" All mutating operations are guarded by an internal "},{"code":"NSLock","type":"codeVoice"},{"type":"text","text":". Callers may push frames"},{"type":"text","text":" "},{"type":"text","text":"from any thread, including AR tracking callback queues."}],"type":"paragraph"},{"anchor":"Usage","level":2,"type":"heading","text":"Usage"},{"syntax":"swift","type":"codeListing","code":["\/\/ Single-source tracking","let driver = ARKitBodyDriver(","    mapper: .default,","    smoothing: .default",")","","func onBodyTracking(_ skeleton: ARKitBodySkeleton) {","    driver.update(","        skeleton: skeleton,","        nodes: vrmModel.nodes,","        humanoid: vrmModel.vrm?.humanoid","    )","}","","\/\/ Multi-source with priority","let driver = ARKitBodyDriver(","    mapper: .default,","    smoothing: .default,","    priority: .latestActive",")","","driver.updateMulti(","    skeletons: [","        \"iPhone\": iPhoneSkeleton,","        \"iPad\": iPadSkel