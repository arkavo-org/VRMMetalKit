{"kind":"article","sections":[],"variants":[{"paths":["\/documentation\/vrmmetalkit\/loadingvrmmodels"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Pick the right loader entry point, drive a progress bar, cancel mid-load, and handle errors."}],"topicSections":[{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMetalKit","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel\/load(from:device:options:)"],"title":"Loading entry points","anchor":"Loading-entry-points"},{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptions","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingProgress","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingPhase","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptimization"],"title":"Configuration","anchor":"Configuration"},{"identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMError"],"title":"Errors","anchor":"Errors"}],"hierarchy":{"paths":[["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit"],["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MigratingFromVRM0"],["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationAndRetargeting","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MigratingFromVRM0"]]},"metadata":{"roleHeading":"API Collection","title":"Loading VRM Models","role":"collectionGroup","modules":[{"name":"VRMMetalKit"}]},"identifier":{"url":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/LoadingVRMModels","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"anchor":"Loading","identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptions","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptimization","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingProgress","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingPhase","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/GLTFParser","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMExtensionParser","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMNodeConstraint","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/BufferLoader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/BufferPreloader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/TextureLoader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ParallelMeshLoader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ParallelTextureLoader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ParallelMaterialLoader"],"title":"Loading","generated":true}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"VRMMetalKit exposes two loader surfaces. "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMetalKit\/loadModel(from:device:)-9dmyj","type":"reference","isActive":true},{"type":"text","text":" and its "},{"type":"codeVoice","code":"Data"},{"type":"text","text":" overload are the convenience facade — one line, default options, no progress hook. "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel\/load(from:device:options:)","type":"reference","isActive":true},{"type":"text","text":" is the underlying entry point; reach for it when you need a progress callback, cancellation, or one of the "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptimization","type":"reference","isActive":true},{"type":"text","text":" presets (for example, "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptimization\/maximumPerformance","type":"reference","isActive":true},{"type":"text","text":" for batch avatar previews)."}],"type":"paragraph"},{"inlineContent":[{"text":"Version detection is transparent. The loader parses the ","type":"text"},{"code":"VRMC_vrm","type":"codeVoice"},{"text":" extension on VRM 1.0 files and the legacy ","type":"text"},{"code":"VRM","type":"codeVoice"},{"text":" extension on VRM 0.x files in the same code path, so the same call site works for both. Material parameter conversion for 0.x is also handled internally — see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MigratingFromVRM0"},{"text":" for the gotchas (MASK demotion, shade-texture aliasing, linearstep vs. smoothstep).","type":"text"}],"type":"paragraph"},{"anchor":"Two-ways-to-load","type":"heading","level":2,"text":"Two ways to load"},{"type":"paragraph","inlineContent":[{"text":"Use the facade for the happy path:","type":"text"}]},{"code":["let model = try await VRMMetalKit.loadModel(from: url, device: device)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel\/load(from:device:options:)","isActive":true},{"type":"text","text":" directly whenever you need to pass a "},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptions","isActive":true},{"type":"text","text":" value. The facade does not forward options — it is the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":" reason to choose one entry point over the other. Note that the "},{"type":"codeVoice","code":"Data"},{"type":"text","text":" overload ("},{"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel\/load(from:filePath:device:)","isActive":true},{"type":"text","text":") does not take options today; load from a "},{"code":"URL","type":"codeVoice"},{"text":" if you need progress or cancellation.","type":"text"}]},{"anchor":"Loading-with-progress-and-cancellation","type":"heading","level":2,"text":"Loading with progress and cancellation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Large avatars with many 4K textures can take several hundred milliseconds to decode. For UI scenarios, wire the load into a "},{"code":"Task","type":"codeVoice"},{"type":"text","text":" and pass a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptions"},{"type":"text","text":" value with a progress callback. The callback fires on the "},{"code":"MainActor","type":"codeVoice"},{"type":"text","text":" no more often than "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptions\/progressUpdateInterval"},{"type":"text","text":", so it is safe to update SwiftUI state from inside it."}]},{"code":["import VRMMetalKit","import Metal","","let device = MTLCreateSystemDefaultDevice()!","","let options = VRMLoadingOptions(","    progressCallback: { progress in","        \/\/ Runs on MainActor. `percentage` is 0...100.","        print(\"Loading: \\(progress.percentage)% — \\(progress.currentPhase.rawValue)\")","    },","    progressUpdateInterval: 0.1,","    enableCancellation: true,","    optimizations: .default",")","","let loadTask = Task {","    try await VRMModel.load(from: modelURL, device: device, options: options)","}","","\/\/ To cancel from elsewhere (e.g. a Cancel button):","\/\/     loadTask.cancel()","\/\/ The loader throws `VRMError.loadingCancelled` at the next phase boundary.","","let model = try await loadTask.value"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingProgress"},{"type":"text","text":" value passed in carries both per-phase fields ("},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingProgress\/currentPhase"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingProgress\/phaseProgress"},{"type":"text","text":") and an aggregated "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingProgress\/overallProgress"},{"type":"text","text":" weighted by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingPhase\/weight"},{"type":"text","text":". Textures dominate the budget at 34% of the total."}]},{"anchor":"Version-detection","type":"heading","level":2,"text":"Version detection"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Detection is automatic. Loading a VRM 0.x "},{"code":".vrm","type":"codeVoice"},{"type":"text","text":" file works without any flag — the internal "},{"code":"VRMExtensionParser","type":"codeVoice"},{"type":"text","text":" inspects "},{"code":"extensions.VRMC_vrm","type":"codeVoice"},{"type":"text","text":" then falls back to "},{"code":"extensions.VRM","type":"codeVoice"},{"type":"text","text":", and the rest of the pipeline branches on the result. You do not call the parser yourself. For the material-side caveats when targeting 0.x assets, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MigratingFromVRM0"},{"type":"text","text":"."}]},{"anchor":"Error-handling","type":"heading","level":2,"text":"Error handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All loader failures throw "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMError"},{"type":"text","text":", which conforms to "},{"code":"LocalizedError","type":"codeVoice"},{"type":"text","text":" so "},{"code":"errorDescription","type":"codeVoice"},{"type":"text","text":" is suitable for direct display. Most cases are recoverable at the UI level (invalid file, missing required extension, unsupported VRM version — show the user a message and move on). "},{"code":"VRMError.loadingCancelled","type":"codeVoice"},{"type":"text","text":" is the expected cooperative cancellation throw and should be treated as a non-error in your UI. Out-of-memory and I\/O failures bubble up as the underlying "},{"code":"Foundation","type":"codeVoice"},{"type":"text","text":" errors and warrant aborting the load entirely."}]}],"kind":"content"}],"references":{"doc://VRMMetalKit/documentation/VRMMetalKit/VRMLoadingOptions/progressUpdateInterval":{"url":"\/documentation\/vrmmetalkit\/vrmloadingoptions\/progressupdateinterval","title":"progressUpdateInterval","role":"symbol","kind":"symbol","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMLoadingOptions\/progressUpdateInterval","abstract":[{"type":"text","text":"Minimum interval in seconds between progress-callback invocations; throttles UI updates."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"progressUpdateInterval","kind":"identifier"},{"text":": ","kind":"text"},{"text":"TimeInterval","preciseIdentifier":"c:@T@NSTimeInterval","kind":"typeIdentifier"}],"type":"topic"},"doc://VRMMetalKit/documentation/VRMMetalKit/VRMError":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VRMError","kind":"identifier"}],"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMError","navigatorTitle":[{"text":"VRMError","kind":"identifier"}],"abstract":[{"text":"Errors raised by VRM loading, validation, and runtime resource setup.","type":"text"}],"type":"topic","url":"\/documentation\/vrmmetalkit\/vrmerror","title":"VRMError","role":"symbol","kind":"symbol"},"doc://VRMMetalKit/documentation/VRMMetalKit/GLTFDocument":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GLTFDocument"}],"title":"GLTFDocument","abstract":[{"text":"Root of a parsed glTF 2.0 document.","type":"text"}],"type"