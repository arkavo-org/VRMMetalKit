{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationAndRetargeting"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vrmmetalkit\/animationandretargeting"]}],"metadata":{"title":"Animation and Retargeting","role":"collectionGroup","modules":[{"name":"VRMMetalKit"}],"roleHeading":"API Collection"},"abstract":[{"type":"text","text":"Load VRMA clips, drive playback with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer"},{"type":"text","text":", and understand how rest-pose retargeting keeps a single clip portable across models."}],"sections":[],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit"]]},"seeAlsoSections":[{"title":"Animation","identifiers":["doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationClip","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/JointTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/MorphTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/ExpressionTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/NodeTrack","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/EulerAxis","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationLoader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationLibrary","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMSkinningSystem","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/SkinnedShader","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationState","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationState\/BoneTransform","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationPresets","doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMMorphTargetSystem"],"generated":true,"anchor":"Animation"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"VRM Animation (","type":"text"},{"code":".vrma","type":"codeVoice"},{"text":") is a glTF-based clip format that stores humanoid joint","type":"text"},{"text":" ","type":"text"},{"text":"rotations, optional ","type":"text"},{"code":"Hips","type":"codeVoice"},{"text":" translation, expression weights, and morph weights","type":"text"},{"text":" ","type":"text"},{"text":"as keyframe tracks. A clip references bones by their VRM humanoid role","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"hips"},{"text":", ","type":"text"},{"type":"codeVoice","code":"leftUpperArm"},{"text":", …) rather than by node index, so the same file can","type":"text"},{"text":" ","type":"text"},{"text":"target any compliant skeleton.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The retargeting promise is simple: a clip authored against one VRM should"},{"type":"text","text":" "},{"type":"text","text":"play cleanly on another VRM with the standard humanoid skeleton, regardless"},{"type":"text","text":" "},{"type":"text","text":"of bone lengths or rest orientations. VRMMetalKit delivers this by combining"},{"type":"text","text":" "},{"type":"text","text":"two independent rest poses at load time — see "},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationAndRetargeting#Retargeting-model","type":"reference"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Loading a clip","anchor":"Loading-a-clip"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationLoader\/loadVRMA(from:model:)"},{"type":"text","text":" to parse a "},{"type":"codeVoice","code":".vrma"},{"type":"text","text":" file."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMAnimationLoader"},{"type":"text","text":" is an enum-namespace (no instance), exposing a single"},{"type":"text","text":" "},{"type":"text","text":"static entry point. Passing the target "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel"},{"type":"text","text":" lets the loader bake"},{"type":"text","text":" "},{"type":"text","text":"rest-pose retargeting and VRM 0.x coordinate conversion into the resulting"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationClip"},{"type":"text","text":" once, instead of paying that cost every frame."}]},{"level":2,"type":"heading","text":"Playing the clip","anchor":"Playing-the-clip"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer","type":"reference","isActive":true},{"type":"text","text":" is a reference type marked "},{"code":"@unchecked Sendable","type":"codeVoice"},{"type":"text","text":". It uses"},{"type":"text","text":" "},{"type":"text","text":"an internal "},{"code":"NSLock","type":"codeVoice"},{"type":"text","text":" and cooperates with "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/VRMModel","type":"reference","isActive":true},{"type":"text","text":"‘s lock, so"},{"type":"text","text":" "},{"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/update(deltaTime:model:)","type":"reference","isActive":true},{"type":"text","text":" may be called from any thread —"},{"type":"text","text":" "},{"type":"text","text":"typically your render loop’s per-frame tick."}]},{"type":"codeListing","syntax":"swift","code":["import VRMMetalKit","","let model: VRMModel = \/* loaded elsewhere *\/","","\/\/ Load with retargeting baked against this model's rest pose.","let clip = try VRMAnimationLoader.loadVRMA(from: clipURL, model: model)","","let player = AnimationPlayer()","player.load(clip)","player.isLooping = true","player.speed = 1.0","player.play()","","\/\/ In your render loop, call once per frame with the elapsed seconds.","\/\/ Safe to call from any thread; the player cooperates with the model's lock.","let dt: Float = 1.0 \/ 60.0","player.update(deltaTime: dt, model: model)"]},{"type":"paragraph","inlineContent":[{"text":"Read ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/time"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/progress"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/isFinished"},{"text":" to drive UI or sequence transitions.","type":"text"}]},{"level":2,"type":"heading","text":"Retargeting model","anchor":"Retargeting-model"},{"type":"paragraph","inlineContent":[{"text":"Animation rest pose and model rest pose are two independent, immutable","type":"text"},{"text":" ","type":"text"},{"text":"sources of truth. You cannot infer one from the other — the clip captures","type":"text"},{"text":" ","type":"text"},{"text":"how its author posed the source rig, while the model captures how its","type":"text"},{"text":" ","type":"text"},{"text":"T-pose was authored. For each humanoid joint with rotation track output","type":"text"},{"text":" ","type":"text"},{"code":"animRotation","type":"codeVoice"},{"text":", VRMMetalKit computes:","type":"text"}]},{"syntax":null,"code":["delta = inverse(animRest) * animRotation","final = modelRest * delta"],"type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"delta"},{"type":"text","text":" is the pure motion the animator intended (the offset from the clip’s"},{"type":"text","text":" "},{"type":"text","text":"own neutral). Pre-multiplying by "},{"type":"codeVoice","code":"modelRest"},{"type":"text","text":" re-anchors that motion onto the"},{"type":"text","text":" "},{"type":"text","text":"target skeleton’s neutral. This is why VRMA clips travel cleanly between"},{"type":"text","text":" "},{"type":"text","text":"models with different rest orientations."}],"type":"paragraph"},{"text":"Root motion and looping","level":2,"anchor":"Root-motion-and-looping","type":"heading"},{"inlineContent":[{"code":"Hips","type":"codeVoice"},{"text":" is the only humanoid bone where translation tracks are honored.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/applyRootMotion","type":"reference"},{"text":" defaults to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", which holds the","type":"text"},{"text":" ","type":"text"},{"text":"character in place; set it to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" to let ","type":"text"},{"code":"Hips","type":"codeVoice"},{"text":" translation drive the","type":"text"},{"text":" ","type":"text"},{"text":"root. ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/isLooping","type":"reference"},{"text":" defaults to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the clip wraps at","type":"text"},{"text":" ","type":"text"},{"text":"its duration), and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VRMMetalKit\/documentation\/VRMMetalKit\/AnimationPlayer\/speed","type":"reference"},{"text":" defaults to ","type":"text"},{"code":"1.0","type":"codeVoice"},{"text":". Scale tracks","type":"text"},{"text":" ","type":"text"},{"text":"and non-","type":"text"},{"code":"Hips","type":"codeVoice"},{"text":" translation tracks are intentionally ignored.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"title":"Loading","id